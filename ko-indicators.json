    "ios_market": {
      "label": "IOS Market Score",
      "category": "sentiment",
      "source": "aggregator",
      "aggregatorKey": "iosMarket",
      "promptKey": "IOS Market Score",
      "promptWeight": "hoch",
      "promptHint": "AA=KAUFEN ERLAUBT, F=SIDELINED. Kombination aus 5 Faktoren"
