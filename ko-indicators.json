      "label": "DXY vs SMA200",
      "category": "macro",
      "source": "computed",
      "symbol": "DX-Y.NYB",
      "domId": "im-dxy",
      "computeFn": "_computeDxySma200",
      "windowVar": "_imDxyBull",
      "promptKey": "DXY",
      "promptWeight": "mittel",
      "promptHint": "Über SMA200 = USD stark = Druck auf Commodities + EM"
    },
    "ndx_breadth": {
      "label": "NDX Breadth >50d MA",
      "category": "macro",
      "source": "dom",
      "domId": "breadth-pct",
      "loadFn": "loadNasdaqBreadth",
      "unit": "%",
      "promptKey": "NDX Breadth (>50d MA)",
      "promptWeight": "mittel",
      "promptHint": "<50% = Markt auf dünnem Eis trotz Index-Stärke"
    },
    "oil_wti": {
      "label": "WTI Rohöl",
      "category": "commodity",
      "source": "dom",
      "symbol": "CL=F",
      "domId": "im-oil",
      "unit": "$",
      "promptKey": "Öl (WTI)",
      "promptWeight": "mittel",
      "promptHint": "Konjunkturindikator, Inflation, Energiesektor"
    },
    "gold": {
      "label": "Gold",
      "category": "commodity",
      "source": "dom",
      "symbol": "GC=F",
      "domId": "im-gold",
      "unit": "$",
      "promptKey": "Gold",
      "promptWeight": "mittel",
      "promptHint": "Safe-Haven, Real-Zinsen-Proxy, USD-Korrelation"
    },
    "copper": {
      "label": "Kupfer",
      "category": "commodity",
      "source": "dom",
      "symbol": "HG=F",
      "domId": "im-cu",
      "unit": "$",
      "promptKey": "Kupfer",
      "promptWeight": "niedrig",
      "promptHint": "Dr. Copper — globaler Konjunkturindikator"
    },
    "lithium": {
      "label": "Lithium (LIT ETF)",
      "category": "commodity",
      "source": "unavailable",
      "symbol": "LIT",
      "domId": null,
      "promptKey": "Lithium (LIT)",
      "promptWeight": "niedrig",
      "promptHint": "EV-Zyklus, Batterietechnologie. Quelle: Yahoo Finance",
      "note": "Noch kein eigenes DOM-Element — Aggregator-Integration geplant"
    },
    "sektor_overheat": {
      "label": "Sektor-Überhitzung",
      "category": "macro",
      "source": "dom",
      "domId": "sektor-overheat-grid",
      "loadFn": "loadSektorOverheat",
      "promptKey": "Sektor-Überhitzung",
      "promptWeight": "mittel",
      "promptHint": "Überhitzte Sektoren meiden, rotierende Sektoren beobachten"
    },
    "sektor_rs": {
      "label": "Sektor RS vs. SPY",
      "category": "macro",
      "source": "dom",
      "domId": "sektor-rs-content",
      "loadFn": "loadSektorRS",
      "promptKey": "Sektor RS vs. SPY",
      "promptWeight": "mittel",
      "promptHint": "Relative Stärke — zeigt Kapitalflüsse zwischen Sektoren"
