    "fear_greed": {
      "label": "Fear & Greed",
      "category": "sentiment",
      "source": "computed",
      "domId": "cnn-fg-score",
      "promptKey": "Fear & Greed CNN",
      "promptWeight": "mittel",
      "promptHint": "0-25 extreme Angst, 75-100 extreme Gier",
      "domIdFallback": "home-fg-val"
    },
    "intermarket_score": {
      "label": "Intermarket Risk Score",
      "category": "macro",
      "source": "dom",
      "domId": "intermarket-score",
      "loadFn": "loadIntermarket",
      "unit": "/100",
      "promptKey": "Intermarket Risk Score",
      "promptWeight": "hoch",
      "promptHint": "0=kein Stress, 100=maximaler Risk-Off"
    },
