{
  "_meta": {
    "version": "1.0.0",
    "created": "2026-07-09",
    "description": "UIQ Indikator-Registry — zentrale Quelle aller Makro-Indikatoren",
    "repository": "ahsub/ko-modules",
    "note": "Neue Indikatoren = neues Objekt. Kein Code-Eingriff nötig."
  },
  "indicators": {
    "vix": {
      "label": "VIX",
      "category": "volatility",
      "source": "aggregator",
      "symbol": "^VIX",
      "domId": "m-vix",
      "unit": "",
      "promptKey": "VIX",
      "promptWeight": "hoch",
      "promptHint": "<16 ruhig, 16-25 normal, >25 Stress, >35 Panik"
    },
    "vix_term": {
      "label": "VIX Termstruktur",
      "category": "volatility",
      "source": "computed",
      "computeFrom": [
        "vix",
        "vix3m"
      ],
      "domId": null,
      "promptKey": "VIX Term Structure",
      "promptWeight": "hoch",
      "promptHint": "CONTANGO=normal, BACKWARDATION=Stress"
    },
    "vvix": {
      "label": "VVIX Z-Score",
      "category": "volatility",
      "source": "aggregator",
      "symbol": "^VVIX",
      "domId": null,
      "promptKey": "VVIX Z-Score(20T)",
      "promptWeight": "mittel",
      "promptHint": "Volatilität der Volatilität — Frühindikator"
    },
    "skew": {
      "label": "SKEW Perzentil",
      "category": "volatility",
      "source": "aggregator",
      "symbol": "^SKEW",
      "domId": null,
      "promptKey": "SKEW Perzentil(20T)",
      "promptWeight": "mittel",
      "promptHint": ">130 = Tail-Risk erhöht"
    },
    "pcr": {
      "label": "Put/Call Ratio",
      "category": "sentiment",
      "source": "aggregator",
      "symbol": null,
      "domId": null,
      "aggregatorKey": "pcr.value",
      "promptKey": "Put/Call Ratio",
      "promptWeight": "mittel",
      "promptHint": ">1.2 bearish Sentiment, <0.7 bullish/überhitzt"
    },
    "pcr_z": {
      "label": "PCR Z-Score (DIX-Proxy)",
      "category": "sentiment",
      "source": "aggregator",
      "domId": null,
      "aggregatorKey": "dix_z20",
      "promptKey": "PCR Z-Score(20T)",
      "promptWeight": "mittel",
      "promptHint": "Ersatz für DIX (Squeezemetrics 403). Negativ = Akkumulation"
