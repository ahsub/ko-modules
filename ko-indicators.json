      "label": "MSE Regime",
      "category": "regime",
      "source": "computed",
      "computeFn": "KoMarketState.getRegime",
      "promptKey": "MSE Regime",
      "promptWeight": "sehr_hoch",
      "promptHint": "BULL_QUIET/BULL_FRAGILE/STRESS_UNSTABLE/POST_PANIC_REVERSION"
