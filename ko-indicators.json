    "aud_usd": {
      "label": "AUD/USD",
      "category": "fx",
      "source": "dom",
      "symbol": "AUDUSD=X",
      "domId": "im-aud",
      "promptKey": "AUD/USD",
      "promptWeight": "niedrig",
      "promptHint": "Risk-On Proxy — steigt wenn Risikobereitschaft hoch"
    },
    "jpy_usd": {
      "label": "JPY/USD",
      "category": "fx",
      "source": "dom",
      "symbol": "JPYUSD=X",
      "domId": "im-jpy",
      "promptKey": "JPY/USD",
      "promptWeight": "niedrig",
      "promptHint": "Safe-Haven — steigt bei Risk-Off (Yen-Stärke)"
