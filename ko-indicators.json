    "gex_proxy": {
      "label": "GEX-Proxy Z-Score",
      "category": "sentiment",
      "source": "aggregator",
      "domId": null,
      "aggregatorKey": "gex_z20",
      "promptKey": "GEX-Proxy Z(20T)",
      "promptWeight": "niedrig",
      "promptHint": "Positiv = Dealer dämpfen Bewegung (Pin-Risk)"
