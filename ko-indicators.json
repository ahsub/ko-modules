      "label": "Bull-Market Frühindikator",
      "category": "macro",
      "source": "dom",
      "domId": "bull-score",
      "loadFn": "calcBullIndicator",
      "promptKey": "Bull-Market Frühindikator",
      "promptWeight": "hoch",
      "promptHint": "Composite aus Breadth, Momentum, Sektor-Rotation"
    },
    "treasury_stress": {
      "label": "Treasury Stress Score",
      "category": "macro",
      "source": "dom",
      "domId": "rc-tsi",
      "loadFn": "calcTreasuryStress",
      "unit": "/100",
      "promptKey": "Treasury Stress Score",
      "promptWeight": "hoch",
      "promptHint": ">60 = Stress im Anleihenmarkt"
    },
    "tnx": {
      "label": "10J Treasury Yield",
      "category": "macro",
      "source": "dom",
      "symbol": "^TNX",
      "domId": "im-tnx",
      "unit": "%",
      "promptKey": "10J Treasury",
      "promptWeight": "hoch",
      "promptHint": "Leitzins-Erwartung, Diskontierungsfaktor Aktien"
    },
    "irx": {
      "label": "3M T-Bill Yield",
      "category": "macro",
      "source": "dom",
      "symbol": "^IRX",
      "domId": "im-irx",
      "unit": "%",
      "promptKey": "Kurzfristzins (3M)",
      "promptWeight": "mittel",
      "promptHint": "Spread zu 10J = Yield-Kurve"
